---
import Base from "../layouts/Base.astro";
---

<Base>
  <main>
    <a href="/">&lt; Home</a>
    <h2>Packliste</h2>
    <p>Für das Camp braucht ihr Folgendes:</p>
    <h3>Für die Teilnahme erforderlich</h3>
    <ul>
      <li>Zelt</li>
      <li>Isomatte</li>
      <li>Schlafsack</li>
      <li>Geschirr (Teller, Messer, Gabel, Löffel, Trinkgefäß)</li>
      <li>Geschirrhandtuch</li>
    </ul>
    <h3>Sonst wichtig</h3>
    <ul>
      <li>(Dusch-)Handtuch</li>
      <li>Duschgel</li>
      <li>Kopfbedeckung (Hut, Käppi)</li>
      <li>Klamotten (auch warm für abends)</li>
      <li>Sonnencreme</li>
      <li>Zahnbürste/Zahnpasta</li>
      <li>Bürste</li>
      <li>Deo</li>
      <li>Taschenlampe</li>
      <li>(optional) 15 m Strom-Verlängerungskabel (power to the tent)</li>
      <li>(optional) 15 m RJ45 LAN-Kabel (lan to the tent)</li>
    </ul>
  </main>
</Base>
