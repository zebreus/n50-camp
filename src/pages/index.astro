---
import "../styles/global.css";
import "../styles/header.css";
import Tents from "../components/Tents.astro";

// Until the CfP closes (03.07.2026 02:00 Europe/Berlin — CEST, so UTC+2) the
// header points at the call for participation; afterwards it points at the
// Fahrplan. Rendered per request (SSR), so this flips on its own at the cutoff.
const fahrplanCutoff = new Date("2026-07-03T02:00:00+02:00");
const showCfp = new Date() < fahrplanCutoff;

// Exclude polyfill on verified chromium browsers (Chrome, Edge, Opera, Brave, Vivaldi, etc.) that support the scroll-driven-animation spec
const ua = Astro.request.headers.get("user-agent") ?? "";
const chromiumMajor = Number(ua.match(/Chrome\/(\d+)/)?.[1] ?? 0);
const needsScrollPolyfillLoader = !(chromiumMajor > 145);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>n50.camp</title>
    {
      needsScrollPolyfillLoader && (
        <script is:inline>
          (() => {
            // load the scroll-driven-animation polyfill only where the browser
            // lacks native support (currently Firefox)
            const hasNativeScrollTimeline =
              globalThis.CSS?.supports?.("animation-timeline", "scroll()") === true;
            if (hasNativeScrollTimeline) {
              return;
            }

            const script = document.createElement("script");
            script.src = "/scroll-driven-animation-polyfill.js";
            script.defer = true;
            document.head.append(script);
          })();
        </script>
      )
    }
  </head>
  <body>
    <header>
      <Tents />
      <div id="wordmark">
        <h1>N50CAMP</h1>
        <nav>
          <ul>
            <li><a href="https://wiki.n50.camp">Wiki</a></li>
            {
              showCfp ? (
                <li>
                  <a href="https://cfp.n50.camp">CfP</a>
                </li>
              ) : (
                <li>
                  <a href="https://fahrplan.n50.camp">Fahrplan</a>
                </li>
              )
            }
            <li><a href="https://engel.n50.camp">Engeln</a></li>
            <li><a href="https://tickets.n50.camp">Tickets</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <div id="header-backdrop" aria-hidden="true"></div>

    <main>
      <p>
        n50.camp ist ein Outdoor-Hacker-Camp, das vom 10. bis 12. Juli 2026 auf
        dem Pfadfinderplatz Greifenhorst (etwa 10 km westlich von Mainz)
        stattfindet. n50.camp ist die erste Camping-Veranstaltung von n50.lat.
      </p>
      <!-- main needs to be high enough so the animation works -->
      <!-- remove these once you added actual content -->
      <!-- or fix the css to give main a minimum height that is correct -->
      <p>GO TOUCH GRASS</p>
      <p>GO TOUCH GRASS</p>
      <p>GO TOUCH GRASS</p>
      <p>GO TOUCH GRASS</p>
      <p>GO TOUCH GRASS</p>
      <p>
        <time datetime="2026-07-10T15:00:00+02:00"
          >10. Juli 2026, 15:00 Uhr</time
        >
        <br />
        bis <br />
        <time datetime="2026-07-12T18:00:00+02:00"
          >12. Juli 2026, 18:00 Uhr</time
        >
        <br />
        <a href="/n50-camp-2026.ics" download>Zum Kalender hinzufügen</a>
      </p>
      <address>
        Pfadfinderplatz Greifenhorst<br />
        St. Georgsweg 1<br />
        55271 Stadecken-Elsheim<br />
        Deutschland
      </address>
      <ul>
        <li>
          <a
            href="https://www.openstreetmap.org/directions?engine=fossgis_osrm_car&route=;49.9100041,8.1212092"
            target="_blank"
            rel="noopener noreferrer"
          >
            Route planen ↗
          </a>
        </li>
        <li>
          <a
            href="https://www.google.com/maps/dir/?api=1&destination=49.9100041%2C8.1212092"
            target="_blank"
            rel="noopener noreferrer"
          >
            Route planen (Google Maps) ↗
          </a>
        </li>
      </ul>
    </main>
    <footer>
      <nav aria-label="Rechtliche Informationen">
        <a href="https://n50.lat/privacypolicy.html">Datenschutzerklärung</a>
        <a href="https://n50.lat/imprint.html">Impressum</a>
        <a href="https://github.com/zebreus/n50-camp">Seite bearbeiten</a>
      </nav>
    </footer>
  </body>
</html>
