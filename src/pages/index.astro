---
import "../styles/global.css";
import Tents from "../components/Tents";
---

<!doctype html>
<html lang="en">
  <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>tents.stl — CSS 3D</title>
      <script is:inline>
        (() => {
          const isFirefox = /Firefox\/\d+|FxiOS\//.test(navigator.userAgent);
          const hasNativeScrollTimeline = globalThis.CSS?.supports?.("animation-timeline", "scroll()") === true;
          if (!isFirefox || hasNativeScrollTimeline) {
            return;
          }

          const script = document.createElement("script");
          script.src = "/n50-scroll-polyfill.js";
          script.defer = true;
          document.head.append(script);
        })();
      </script>
  </head>
  <body>
    <header id="camera">
      <Tents />
      <!-- wordmark is a real object in the 3D scene: it lies on the floor in
           front of the tents in the hero, then animates its 3D position and
           rotation to stand up as a caption below them (CSS only). -->
      <div id="wordmark">
        <span aria-hidden="true">N50CAMP</span>
        <ul class="wordmark-links">
          <li><a href="https://wiki.n50.camp">Wiki</a></li>
          <li><a href="https://pretalx.n50.camp">Fahrplan</a></li>
          <li><a href="https://engel.n50.camp">Engeln</a></li>
          <li><a href="https://tickets.n50.camp">Tickets</a></li>
        </ul>
      </div>
    </header>
    <div id="header-backdrop" aria-hidden="true"></div>

    <main id="content">
      <p class="lede">
        n50.camp ist ein Outdoor-Hacker-Camp, das vom 10. bis 12. Juli 2026 auf
        dem Pfadfinderplatz Greifenhorst (etwa 10 km westlich von Mainz)
        stattfindet. n50.camp ist die erste Camping-Veranstaltung von n50.lat.
      </p>
      <p>GO TOUCH GRASS</p>
      <p>
        <time datetime="2026-07-10T15:00:00+02:00">10. Juli 2026, 15:00 Uhr</time>
        <br />
        bis <br />
        <time datetime="2026-07-12T18:00:00+02:00">12. Juli 2026, 18:00 Uhr</time>
        <br />
        <a href="/n50-camp-2026.ics" download>Zum Kalender hinzufügen</a>
      </p>
      <address>
        Pfadfinderplatz Greifenhorst<br />
        St. Georgsweg 1<br />
        55271 Stadecken-Elsheim<br />
        Deutschland
      </address>
      <ul>
        <li>
          <a
            href="https://www.openstreetmap.org/directions?engine=fossgis_osrm_car&route=;49.9100041,8.1212092"
            target="_blank"
            rel="noopener noreferrer"
          >
            Route planen ↗
          </a>
        </li>
        <li>
          <a
            href="https://www.google.com/maps/dir/?api=1&destination=49.9100041%2C8.1212092"
            target="_blank"
            rel="noopener noreferrer"
          >
            Route planen (Google Maps) ↗
          </a>
        </li>
      </ul>
    </main>
    <footer id="site-footer">
      <nav aria-label="Rechtliche Informationen">
        <a href="https://n50.lat/privacypolicy.html">Datenschutzerklärung</a>
        <a href="https://n50.lat/imprint.html">Impressum</a>
      </nav>
    </footer>
  </body>
</html>
